{
  "name": "@openwx/core",
  "version": "0.1.0",
  "description": "Protocol-facing iLink Bot API client, auth, polling, media, and persistence helpers for openWX.",
  "keywords": [
    "openwx",
    "wechat",
    "ilink",
    "bot",
    "sdk",
    "protocol"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/B4yesC4t/openWX.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/B4yesC4t/openWX/issues"
  },
  "homepage": "https://github.com/B4yesC4t/openWX#readme",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts --format esm --dts --watch --out-dir dist",
    "lint": "eslint src tests",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/qrcode": "1.5.5",
    "@types/qrcode-terminal": "0.12.2",
    "nock": "14.0.10"
  },
  "dependencies": {
    "qrcode": "1.5.4",
    "qrcode-terminal": "0.12.0"
  }
}
