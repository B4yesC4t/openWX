{
  "name": "@openwx/hub",
  "version": "0.1.0",
  "description": "Routing and configuration scaffold for multi-application openWX deployments.",
  "keywords": [
    "openwx",
    "wechat",
    "hub",
    "router",
    "bot",
    "ilink"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openwx-hub": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/B4yesC4t/openWX.git",
    "directory": "packages/hub"
  },
  "bugs": {
    "url": "https://github.com/B4yesC4t/openWX/issues"
  },
  "homepage": "https://github.com/B4yesC4t/openWX#readme",
  "dependencies": {
    "@openwx/bot": "workspace:*",
    "@openwx/core": "workspace:*",
    "yaml": "^2.8.3"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --out-dir dist --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --watch --out-dir dist --tsconfig tsconfig.build.json",
    "lint": "eslint src tests",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
