{
  "name": "openwx",
  "private": true,
  "version": "0.1.0",
  "description": "TypeScript SDK monorepo for connecting applications and AI agents to WeChat through the official iLink Bot API.",
  "keywords": [
    "wechat",
    "ilink",
    "bot",
    "sdk",
    "typescript",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/B4yesC4t/openWX.git"
  },
  "bugs": {
    "url": "https://github.com/B4yesC4t/openWX/issues"
  },
  "homepage": "https://github.com/B4yesC4t/openWX#readme",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node ./scripts/run-workspace-script.mjs build",
    "typecheck": "node ./scripts/run-workspace-script.mjs typecheck",
    "lint": "eslint tests vitest.config.ts && node ./scripts/run-workspace-script.mjs lint",
    "test": "vitest run --config vitest.config.ts && node ./scripts/run-workspace-script.mjs test",
    "dev": "node ./scripts/run-workspace-script.mjs dev --parallel",
    "format": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vitest": "4.1.0"
  }
}
